# =============================================================================
# TenacitOS-X Configuration
# =============================================================================
# Copy this file to .env.local and fill in your values:
#   cp .env.example .env.local
#
# Generate secrets with: openssl rand -base64 32

# --- Auth ---
# Required: used for session cookies and TOTP encryption
AUTH_SECRET=generate-a-random-32-char-string-here

# Legacy: if set and no auth.db exists, auto-creates admin with this password
# Remove after migrating to multi-user auth
ADMIN_PASSWORD=change-me-to-a-strong-password

# --- Next.js ---
# Comma-separated origins allowed in dev mode (e.g., LAN IP for remote access)
# ALLOWED_DEV_ORIGINS=http://192.168.1.100:3000

# --- OpenClaw ---
# Paths (defaults shown - override if your setup differs)
# OPENCLAW_DIR=/root/.openclaw
# OPENCLAW_WORKSPACE=/root/.openclaw/workspace

# Gateway URL for agent control and AI chat
GATEWAY_URL=http://localhost:3001

# --- Docker (optional) ---
# Standard Docker host URI — supports unix:// and tcp:// schemes
# Examples:
#   DOCKER_HOST=unix:///var/run/docker.sock
#   DOCKER_HOST=tcp://192.168.1.100:2375
# DOCKER_HOST=
#
# Legacy: set if Docker socket is not at the default path (prefer DOCKER_HOST)
# DOCKER_SOCKET=/var/run/docker.sock

# --- Alerts (optional) ---
# Telegram bot token for alert delivery
# TELEGRAM_BOT_TOKEN=

# SMTP for email alerts
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=tenacitos@yourdomain.com

# --- PWA Push Notifications (optional) ---
# Generate with: npx web-push generate-vapid-keys
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_EMAIL=mailto:admin@yourdomain.com

# --- Fleet ---
# Collector API keys are generated in the dashboard UI, not here
# FLEET_RETENTION_DAYS=30

# --- Branding (customize for your instance) ---
NEXT_PUBLIC_AGENT_NAME=Mission Control
NEXT_PUBLIC_AGENT_EMOJI=🤖
NEXT_PUBLIC_AGENT_DESCRIPTION=Your AI co-pilot, powered by OpenClaw
NEXT_PUBLIC_AGENT_LOCATION=
NEXT_PUBLIC_BIRTH_DATE=
NEXT_PUBLIC_AGENT_AVATAR=
NEXT_PUBLIC_OWNER_USERNAME=your-username
NEXT_PUBLIC_OWNER_EMAIL=your-email@example.com
NEXT_PUBLIC_OWNER_COLLAB_EMAIL=collabs@example.com
NEXT_PUBLIC_TWITTER_HANDLE=@username
NEXT_PUBLIC_COMPANY_NAME=MISSION CONTROL, INC.
NEXT_PUBLIC_APP_TITLE=Mission Control
